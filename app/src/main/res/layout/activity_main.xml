<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_main_page"
            android:fillViewport="true"
            android:fitsSystemWindows="true">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="40dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

        <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="快速操作"
                android:textColor="@color/headline"
                android:textSize="30sp"
                android:textStyle="bold"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="入口和环境信息"
                android:textColor="@color/subtle_text"
                android:textSize="15sp"/>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:background="@drawable/bg_panel_surface"
                android:elevation="3dp"
                android:padding="18dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:text="屏幕宽高"
                        android:textColor="@color/subtle_text"
                        android:textSize="13sp"/>

                <TextView
                        android:id="@+id/tvInfoScreenValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="--"
                        android:textColor="@color/headline"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:text="规则覆盖"
                        android:textColor="@color/subtle_text"
                        android:textSize="13sp"/>

                <TextView
                        android:id="@+id/tvInfoRulesValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="--"
                        android:textColor="@color/headline"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <Button
                android:id="@+id/btnStartSwipeUp"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_action_swipe"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="开始上滑"
                android:textAllCaps="false"
                android:textColor="@color/action_text"
                android:textSize="17sp"
                android:textStyle="bold"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginTop="8dp"
                android:text="固定 3 秒节奏循环上滑，适合连续翻页。"
                android:textColor="@color/subtle_text"
                android:textSize="13sp"/>

        <Button
                android:id="@+id/btnStartClick"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_action_click"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="开始点击"
                android:textAllCaps="false"
                android:textColor="@color/action_text"
                android:textSize="17sp"
                android:textStyle="bold"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginTop="8dp"
                android:text="点击后停留 35 秒，再返回并进入下一轮。"
                android:textColor="@color/subtle_text"
                android:textSize="13sp"/>

        <Button
                android:id="@+id/btnStartOcr"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_action_ocr"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="开启 OCR"
                android:textAllCaps="false"
                android:textColor="@color/action_text"
                android:textSize="17sp"
                android:textStyle="bold"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginTop="8dp"
                android:text="单独开启页面识别和规则执行，不绑定固定任务。"
                android:textColor="@color/subtle_text"
                android:textSize="13sp"/>

        <Button
                android:id="@+id/btnToggleCoordinateLocator"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_panel_surface"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="定位屏幕坐标"
                android:textAllCaps="false"
                android:textColor="@color/headline"
                android:textSize="17sp"
                android:textStyle="bold"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginTop="8dp"
                android:text="显示可拖动定位浮窗，实时查看点击比例坐标。"
                android:textColor="@color/subtle_text"
                android:textSize="13sp"/>

    </LinearLayout>
</ScrollView>
